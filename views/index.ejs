<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>

  </title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet"
    integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">
</head>

<body>
  <div>
    <nav class="navbar navbar-expand-lg bg-body-tertiary">
      <div class="container-fluid">
        <a class="navbar-brand" href="#">Navbar</a>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarSupportedContent"
          aria-controls="navbarSupportedContent" aria-expanded="false" aria-label="Toggle navigation">
          <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="navbarSupportedContent">
          <ul class="navbar-nav me-auto mb-2 mb-lg-0">
            <li class="nav-item">
              <a class="nav-link active" aria-current="page" href="#">Home</a>
            </li>
            <li class="nav-item">
              <a class="nav-link" href="#">Link</a>
            </li>
            <li class="nav-item dropdown">
              <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown"
                aria-expanded="false">
                Dropdown
              </a>
              <ul class="dropdown-menu">
                <li><a class="dropdown-item" href="#">Action</a></li>
                <li><a class="dropdown-item" href="#">Another action</a></li>
                <li>
                  <hr class="dropdown-divider">
                </li>
                <li><a class="dropdown-item" href="#">Something else here</a></li>
              </ul>
            </li>
            <li class="nav-item">
              <a class="nav-link disabled" aria-disabled="true">Disabled</a>
            </li>
          </ul>
          <form class="d-flex" role="search">
            <input class="form-control me-2" name="keyword" type="search" placeholder="Search" aria-label="Search">
            <button class="btn btn-outline-success" type="submit">Search</button>
          </form>
        </div>
      </div>
    </nav>
    <h1>Home</h1>
    <img
      src="https://lh3.googleusercontent.com/pw/AP1GczP2tzO_gXHTW5YKjvJ66ThaqoCdvJ5ZVM3ubhCmdgfhugUjiwnYdqiufvQfBTHsXLO3svZpsY5wrv2ofT7L42kLp2rT7muqTD-ElkKmF4ZgVCNmZ-N9Ptk6tO1AtjMhYuk1_FBQiYwww9Dq2B--W5nv=w2340-h609-s-no-gm?authuser=0"
      class="img-fluid" alt="...">
    <h2 class="text-center mt-2 py-3 ">ĐỒNG HỒ NAM BÁN CHẠY</h2>
    <div>
      <div class="container py-20">
        <div class="row">
          <% data.map((watch) => { %>
            <div class="col-md-3">
                <a href="/watch/<%= watch.id %>" class="text-decoration-none text-dark"> <!-- Thay thế bằng URL bạn muốn điều hướng -->
                    <div class="card border-0" style="width: 16rem;">
                        <div class="text-center">
                            <img src="<%= watch.image %>" class="card-img-top w-75" alt="<%= watch.watchName %>">
                        </div>
                        <div class="card-body text-center fs-6">
                          <p class="text-truncate"><%= watch.brand.brandName %></p>
                            <p class="text-truncate"><%= watch.watchName %></p>
                            <p class="card-text text-danger "><%= watch.price.toLocaleString('vi-VN') +" ₫"%></p>
                        </div>
                    </div>
                </a>
            </div>         
        <% }) %>
        </div>
      </div>
      <footer class="bg-dark text-white text-center py-3">
        <div class="container">
            <p class="mb-0">© 2024 Công ty Tân Triều. Tất cả các quyền được bảo lưu.</p>
            <ul class="list-unstyled d-flex justify-content-center mb-0">
                <li class="mx-3"><a href="#" class="text-white">Giới thiệu</a></li>
                <li class="mx-3"><a href="#" class="text-white">Dịch vụ</a></li>
                <li class="mx-3"><a href="#" class="text-white">Liên hệ</a></li>
                <li class="mx-3"><a href="#" class="text-white">Chính sách bảo mật</a></li>
            </ul>
        </div>
    </footer>
    
    </div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"
      integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz"
      crossorigin="anonymous"></script>
</body>

</html>