<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Register Page</title>
    <link rel="stylesheet" href="./css/register.css">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet"
        integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">
</head>

<body>
     <!-- Toast Notification -->
     <div class="toast" id="errorToast" role="alert" aria-live="assertive" aria-atomic="true" style="position: absolute; top: 20px; right: 20px; display: none;">
        <div class="toast-header">
            <strong class="me-auto">Thông báo lỗi</strong>
            <small>vừa xong</small>
            <button type="button" class="btn-close" data-bs-dismiss="toast" aria-label="Close"></button>
        </div>
        <div class="toast-body" id="toastBody"></div>
    </div>

    <section class="vh-100 gradient-custom">
        <div class="container h-100">
            <div class="row justify-content-center align-items-center h-100">
                <div class="col-12 col-lg-9 col-xl-7">
                    <div class="card shadow-2-strong card-registration" style="border-radius: 15px;">
                        <div class="card-body p-4 p-md-5">
                            <h3 class="mb-4 pb-2 pb-md-0 mb-md-5">Registration Form</h3>
                            <form action="/api/auth/register" method="post" id="registrationForm"
                                onsubmit="return validateForm()">
                                <div class="row mb-4">
                                    <div class="col-md-6">
                                        <div class="form-outline">
                                            <label class="form-label" for="firstName">Member Name</label>
                                            <input type="text" name="memberName" id="firstName"
                                                class="form-control form-control-lg" required />
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="form-outline">
                                            <label class="form-label" for="lastName">Name</label>
                                            <input type="text" name="name" id="lastName"
                                                class="form-control form-control-lg" required />
                                        </div>
                                    </div>
                                </div>
                                <div class="row mb-4">
                                    <div class="col-md-6">
                                        <div class="form-outline">
                                            <label for="password" class="form-label">Password</label>
                                            <input type="password" name="password" id="password"
                                                class="form-control form-control-lg" required />
                                            <small id="passwordError" class="text-danger d-none">Password must be at
                                                least 6 characters long.</small>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="form-outline">
                                            <label class="form-label" for="confirmPassword">Confirm Password</label>
                                            <input type="password" id="confirmPassword"
                                                class="form-control form-control-lg" required />
                                            <small id="confirmPasswordError" class="text-danger d-none">Passwords do not
                                                match.</small>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="form-outline">
                                            <label class="form-label" for="confirmPassword">Phone number</label>
                                            <input type="text" id="confirmPassword" name="phoneNumber"
                                                class="form-control form-control-lg" required />
                                            <small id="confirmPasswordError" class="text-danger d-none">Passwords do not
                                                match.</small>
                                        </div>
                                    </div>
                                </div>
                                <div class="mt-4">
                                    <input id="sendRequest"  class="btn btn-primary btn-lg" type="submit" value="Submit" />
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>
    <script>
        document.getElementById('sendRequest').addEventListener('click', async () => {
            try {
                const response = await fetch('/api/some-endpoint', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                    },
                    body: JSON.stringify({ data: 'test' }) // Thay đổi dữ liệu theo nhu cầu
                });

                const result = await response.json();

                // Kiểm tra xem có lỗi không
                if (!response.ok) {
                    // Gán nội dung lỗi vào toast và hiển thị
                    document.getElementById('toastBody').innerText = result.messageError;
                    const toast = new bootstrap.Toast(document.getElementById('errorToast'));
                    document.getElementById('errorToast').style.display = 'block'; // Hiển thị toast
                    toast.show();
                } else {
                    console.log(result); // Xử lý thành công
                }
            } catch (error) {
                console.error('Có lỗi xảy ra:', error);
            }
        });
    </script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"
        integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz"
        crossorigin="anonymous"></script>
    <script>
        function validateForm() {
            const password = document.getElementById('password').value;
            const confirmPassword = document.getElementById('confirmPassword').value;
            let isValid = true;

            // Reset error messages
            document.getElementById('passwordError').classList.add('d-none');
            document.getElementById('confirmPasswordError').classList.add('d-none');

            // Validate password length
            if (password.length < 6) {
                document.getElementById('passwordError').classList.remove('d-none');
                isValid = false;
            }

            // Validate password match
            if (password !== confirmPassword) {
                document.getElementById('confirmPasswordError').classList.remove('d-none');
                isValid = false;
            }

            return isValid; // Prevent form submission if not valid
        }
    </script>
</body>

</html>