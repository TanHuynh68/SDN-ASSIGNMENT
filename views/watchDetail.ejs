<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet"
        integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">
    <link href="https://cdn.jsdelivr.net/npm/@coreui/coreui-pro@5.5.0/dist/css/coreui.min.css" rel="stylesheet"
        integrity="sha384-r/2d1aBwRhQSqjQh/21GvBPd8Oq6JOk0rWn05ngWyhiPOL79wFjw7vcbn3HwYGC/" crossorigin="anonymous">
</head>

<body>
    <div class="container">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a href="/">Home</a></li>
                <li class="breadcrumb-item active" aria-current="page">Library</li>
            </ol>
        </nav>
        <div class="row mt-5">
            <div class="col-md-6 text-center ">
                <img class="w-100" src="<%= data.image %>" alt="">
            </div>
            <div class="col-md-6">
                <p class="fs-3 fw-bold mb-0">
                    <%= data.brand.brandName %>
                </p>
                <p class="fs-5 fw-bold">
                    <%= data.watchName %>
                </p>
                <p class="fs-3 text-danger">
                    <%= data.price.toLocaleString('vi-VN')+" ₫" %>
                </p>
                <p class="fs-6">
                    <%= data.watchDescription %>
                </p>
            </div>
        </div>
        <div class="row d-flex justify-content-center">
            <div class="col-md-8 col-lg-6">
                <div class="card shadow-0 border" style="background-color: #f0f2f5;">
                    <div class="card-body p-4">
                        <div data-mdb-input-init class="form-outline mb-4">
                            <form action="/api/members/comment/<%= data._id %>" method="POST">
                                <input type="hidden" name="author" value=<%=dataUser %> id="author">
                                <!-- <input type="hidden" name="rating" value="3" id="rating"> -->
                                <select name="rating" class="form-select" aria-label="Default select example">
                                    <option selected>Choose rating</option>
                                    <option value="1">bad</option>
                                    <option value="2">not bad</option>
                                    <option value="3">good</option>
                                </select>
                                <input name="content" type="text" id="content" class="form-control"
                                    placeholder="Type comment..." required />
                                <button type="submit" class="btn btn-primary mt-2">+ Add comment</button>
                            </form>

                        </div>

                        <% data.comments.forEach(function(comment) { %>
                            <div class="card mb-4">
                                <div class="card-body">
                                    <p>
                                        <% if (comment.author) { %>
                                            <p>
                                                <%= comment.author.memberName %>
                                                    <%= new Date(comment.createdAt).toLocaleDateString('vi-VN') %>
                                                        <% if (comment.rating===1) { %>
                                                            bad
                                                            <% } else if (comment.rating===2) { %>
                                                                not bad
                                                                <% } else if (comment.rating===3) { %>
                                                                    good
                                                                    <% } %>
                                            </p>
                                            <% } else { %>
                                                <p>Anonymous</p> <!-- Hoặc một thông báo khác nếu không có tác giả -->
                                                <% } %>
                                    </p>

                                    <div class="d-flex justify-content-between">

                                        <div class="d-flex flex-row align-items-center">
                                            <img src="data:image/jpeg;base64,"
                                                alt="avatar" width="25" height="25" />
                                            <p class="small mb-0 ms-2 ">
                                                <%= comment.content %>
                                            </p>

                                        </div>
                                        <div class="d-flex flex-row align-items-center">
                                            <p class="small text-muted mb-0">Upvote?</p>
                                            <i class="far fa-thumbs-up mx-2 fa-xs text-body"
                                                style="margin-top: -0.16rem;"></i>
                                            <p class="small text-muted mb-0"></p>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <% }) %>

                    </div>
                </div>
            </div>
        </div>
    </div>
    </div>
    <footer class="bg-dark text-white text-center py-3 mt-3">
        <div class="container">
            <p class="mb-0">© 2024 Công ty Tân Triều. Tất cả các quyền được bảo lưu.</p>
            <ul class="list-unstyled d-flex justify-content-center mb-0">
                <li class="mx-3"><a href="#" class="text-white">Giới thiệu</a></li>
                <li class="mx-3"><a href="#" class="text-white">Dịch vụ</a></li>
                <li class="mx-3"><a href="#" class="text-white">Liên hệ</a></li>
                <li class="mx-3"><a href="#" class="text-white">Chính sách bảo mật</a></li>
            </ul>
        </div>
    </footer>
    <script>
        const watchId = button.getAttribute('data-watchid');
        const watchName = button.getAttribute('data-watchname');
        const image = button.getAttribute('data-image');
        const price = button.getAttribute('data-price');
        // Hàm xử lý sự kiện khi nhấn nút 'Add a note'
        addCommentBtn.addEventListener('click', async function () {
            const commentText = commentInput.value;
            const authorId = authorInput.value;
            const rating = ratingInput.value;

            // Kiểm tra các trường có dữ liệu hợp lệ không
            if (commentText.trim() && authorId.trim() && rating.trim()) {
                try {
                    // Gọi API với method POST
                    const response = await fetch('http://localhost:5000/api/members/comment/6712cda7c4e7798f85fd8437', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json',
                        },
                        body: JSON.stringify({
                            content: commentText,
                            author: authorId,
                            rating: rating
                        }),
                    });

                    if (response.ok) {
                        const newComment = await response.json();

                        // Thêm comment mới vào danh sách
                        const newCommentElement = document.createElement('li');
                        newCommentElement.textContent = `Comment: ${newComment.content}, Rating: ${newComment.rating}`;
                        commentList.appendChild(newCommentElement);

                        // Reset input sau khi thêm comment thành công
                        commentInput.value = '';
                        authorInput.value = '';
                        ratingInput.value = '';
                    } else {
                        alert('Failed to add comment. Please try again.');
                    }
                } catch (error) {
                    console.error('Error:', error);
                    alert('An error occurred. Please try again later.');
                }
            } else {
                alert('Please fill in all fields!');
            }
        });

    </script>
    <script src="https://cdn.jsdelivr.net/npm/@coreui/coreui@5.1.2/dist/js/bootstrap.bundle.min.js"
        integrity="sha384-i+Yu7CmJG/p8FA6Avyg4ZheFvxNjJQ5taj5ArZf94yQt1lWZiVwkXyPrgE/QqbJi"
        crossorigin="anonymous"></script>
</body>

</html>